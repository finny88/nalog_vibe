{
	"extends": "./base.json",
	"compilerOptions": {
		"target": "ES2022",
		"useDefineForClassFields": true,
		"lib": ["ES2024", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"types": ["vite/client", "vite-plugin-svgr/client"],
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"moduleDetection": "force",
		"noEmit": true,
		"jsx": "react-jsx"
	}
}