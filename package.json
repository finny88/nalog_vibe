{
	"name": "nalog-vibe",
	"version": "0.0.0",
	"private": true,
	"packageManager": "yarn@4.6.0",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "node ./scripts/run-workspaces.mjs build",
		"db:down": "docker compose down",
		"db:logs": "docker compose logs -f postgres",
		"db:prisma:generate": "yarn workspace @nalog-vibe/api prisma:generate",
		"db:prisma:migrate": "yarn workspace @nalog-vibe/api prisma:migrate",
		"db:up": "docker compose up -d postgres",
		"dev": "node ./scripts/run-workspaces.mjs dev",
		"dev:api": "yarn workspace @nalog-vibe/api dev",
		"dev:web": "yarn workspace @nalog-vibe/web dev",
		"format": "yarn exec prettier . --write",
		"format:check": "yarn exec prettier . --check",
		"lint": "node ./scripts/run-workspaces.mjs lint",
		"lint:affected": "node ./scripts/workspace-checks.mjs lint",
		"lint:staged-workspaces": "node ./scripts/workspace-checks.mjs lint --staged",
		"prepare": "husky",
		"test": "node ./scripts/run-workspaces.mjs test",
		"typecheck": "node ./scripts/run-workspaces.mjs typecheck",
		"typecheck:affected": "node ./scripts/workspace-checks.mjs typecheck",
		"typecheck:staged": "node ./scripts/workspace-checks.mjs typecheck --staged"
	},
	"lint-staged": {
		"**/*.{json,md,css,scss,cjs,mjs,yml,yaml}": [
			"yarn exec prettier --write --ignore-unknown"
		],
		"apps/**/*.{js,jsx,ts,tsx}": [
			"yarn exec prettier --write --ignore-unknown",
			"yarn exec eslint --fix --max-warnings 0"
		],
		"packages/**/*.{js,ts,tsx}": [
			"yarn exec prettier --write --ignore-unknown",
			"yarn exec eslint --fix --max-warnings 0"
		],
		"scripts/**/*.{js,mjs}": [
			"yarn exec prettier --write --ignore-unknown",
			"yarn exec eslint --fix --max-warnings 0"
		]
	},
	"devDependencies": {
		"@eslint/js": "9.39.1",
		"@feature-sliced/eslint-config": "0.1.1",
		"@playwright/test": "1.50.1",
		"@stylistic/eslint-plugin": "5.7.0",
		"@types/node": "24.10.1",
		"@types/react": "19.2.5",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "5.1.1",
		"eslint": "9.39.1",
		"eslint-config-prettier": "10.1.3",
		"eslint-import-resolver-typescript": "4.4.4",
		"eslint-plugin-boundaries": "5.4.0",
		"eslint-plugin-import": "2.32.0",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-refresh": "0.4.24",
		"globals": "16.5.0",
		"husky": "9.1.7",
		"lerna": "8.2.4",
		"lint-staged": "16.2.7",
		"postcss": "8.5.6",
		"postcss-preset-mantine": "1.18.0",
		"postcss-simple-vars": "7.0.1",
		"prettier": "3.6.2",
		"prisma": "6.11.1",
		"tsx": "4.19.3",
		"typescript": "5.9.3",
		"typescript-eslint": "8.46.4",
		"vite": "7.3.1",
		"vite-plugin-checker": "0.12.0",
		"vite-plugin-svgr": "4.5.0",
		"vite-tsconfig-paths": "5.1.4",
		"vitest": "4.0.16"
	}
}